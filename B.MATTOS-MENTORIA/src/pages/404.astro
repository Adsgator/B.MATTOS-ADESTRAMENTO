---
// src/pages/404.astro
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';

const pageTitle = "404 . Página não encontrada | Beatriz Mattos";
const pageDescription = "Ops! Parece que você se perdeu. A página que você procura não existe.";
---

<Layout title={pageTitle} description={pageDescription} robots="noindex" canonicalUrl="https://mentoria.abeak9adestramento.com.br/404" hideNavLinks={true}>
  <main class="relative z-10 flex flex-col items-center justify-center text-center py-section-mobile-py xl:py-section px-5 max-w-content mx-auto min-h-[70vh]">
    <!-- Numeral decorativo -->
    <div class="num-404 font-display text-[30vw] text-foreground opacity-[0.04] absolute inset-0 flex items-center justify-center pointer-events-none select-none leading-none z-0">
      404
    </div>

    <div class="relative z-10 flex flex-col items-center gap-8 max-w-md">


      <div class="flex flex-col gap-4">
        <h1 class="font-display text-h2 text-foreground">Esse endereço não existe.</h1>
        <p class="font-sans text-body text-muted-foreground">
          Mas o que você procura, está aqui.
        </p>
      </div>

      <div class="mt-6 w-full max-w-xs mx-auto">
        <Button
          label="Voltar ao início"
          href="/"
          variant="primary"
          trackingId="btn-404-home"
          section="404"
          class="w-full py-4"
        />
      </div>
    </div>
  </main>

  <script>
    import gsap from 'gsap';
    
    document.addEventListener('DOMContentLoaded', () => {
      gsap.to('.num-404', {
        y: -20,
        duration: 4,
        repeat: -1,
        yoyo: true,
        ease: 'sine.inOut',
      });
    });
  </script>
</Layout>
