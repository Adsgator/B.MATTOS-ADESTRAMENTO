---
import { Image } from 'astro:assets';
import Button from './Button.astro';
import logoBranca from '../../assets/images/logo-branca-sheforcek9.svg';

const navLinks = [
  { label: 'O Curso',       href: '#servico' },
  { label: 'Diferenciais',  href: '#diferenciais' },
  { label: 'Como Funciona', href: '#como-funciona' },
  { label: 'Investimento',  href: '#precos' },
  { label: 'FAQ',           href: '#faq' },
];
---

<header
  id="site-header"
  class="
    fixed top-0 left-0 right-0 z-50
    transition-colors duration-200
    bg-dark
    [&.header-scrolled]:backdrop-blur-md [&.header-scrolled]:bg-dark/95
  "
>
  <div class="container-content flex items-center justify-between h-auto py-4 lg:py-6 gap-8">

    <!-- Logo -->
    <a
      href="#top"
      aria-label="She ForceK9 — ir para o topo"
      class="flex items-center group flex-shrink-0"
    >
      <Image
        src={logoBranca}
        alt="She ForceK9 Logo"
        width={180}
        height={50}
        class="h-16 lg:h-20 w-auto object-contain"
      />
    </a>

    <!-- Nav Desktop -->
    <nav aria-label="Navegação principal" class="hidden lg:flex items-center gap-8">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class="
            font-sans text-body-sm font-medium text-white/70
            hover:text-white transition-colors duration-150
            focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary
          "
        >
          {label}
        </a>
      ))}
    </nav>


    <!-- Hambúrguer Mobile — island React com Framer Motion -->
    <div class="lg:hidden ml-auto" id="mobile-menu-trigger">
      <!-- MobileMenu.tsx montado via island client:load -->
    </div>

  </div>
</header>

<!-- Island MobileMenu React -->
<script>
  import MobileMenu from '../islands/MobileMenu';
  import { createElement } from 'react';
  import { createRoot } from 'react-dom/client';

  const trigger = document.getElementById('mobile-menu-trigger');
  if (trigger) {
    const root = createRoot(trigger);
    root.render(
      createElement(MobileMenu, {
        links: [
          { label: 'O Curso',       href: '#servico' },
          { label: 'Diferenciais',  href: '#diferenciais' },
          { label: 'Como Funciona', href: '#como-funciona' },
          { label: 'Investimento',  href: '#precos' },
          { label: 'FAQ',           href: '#faq' },
        ],
      })
    );
  }
</script>
