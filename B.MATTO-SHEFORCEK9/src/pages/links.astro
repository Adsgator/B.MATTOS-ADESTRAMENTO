  <main class="links-container">

    <!-- Logo -->
    <a href="https://sheforcek9.abeak9adestramento.com.br" class="links-logo">She ForceK9</a>

    <!-- Avatar circular -->
    <div class="links-avatar" role="img" aria-label="Foto de Beatriz Mattos, instrutora She ForceK9">
