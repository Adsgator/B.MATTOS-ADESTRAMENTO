---
import SectionHeader from '../components/global/SectionHeader.astro';
import Button from '../components/global/Button.astro';
import { Image } from 'astro:assets';
import beatrizImage from '../assets/images/beatriz_mattos.webp';

const whatsappHref = 'https://wa.me/5511918952921?text=Oi%2C%20vi%20voc%C3%AA%20no%20Google%20e%20gostaria%20de%20saber%20mais%20sobre%20o%20curso%20She%20ForceK9';

const itens = [
  { title: 'Visão 360º do Mercado', text: 'Nossa equipe une perspectivas complementares: técnica canina, comportamento humano e respaldo jurídico. Uma visão completa que poucos cursos no Brasil oferecem.' },
  { title: 'Experiência com Diversos Perfis', text: 'Volume real de atendimento com diversas raças, temperamentos e problemas comportamentais, gerando uma leitura refinada e precisa de cada cão.' },
  { title: 'Atualização Contínua', text: 'Estudo constante e profundo que se reflete na didática e na forma eficaz de resolver problemas complexos de forma segura.' },
  { title: 'Troca Sem Segredos', text: 'O valor está em transmitir o conhecimento, não em retê-lo. Entregamos técnicas e informações sem segredos e sem ego.' },
  { title: 'Didática Direta e Prática', text: 'Sem teorias místicas ou excessivas. Clareza, segurança, sequência lógica e aplicação imediata para resultados reais.' },
  { title: 'Foco no Fator Humano', text: 'Uma leitura fina da pessoa por trás do cachorro. As orientações são precisas, transformadoras e acolhedoras, sem perder a firmeza necessária.' },
  { title: 'Liderança no Nicho Feminino', text: 'Pioneirismo ao guiar mulheres para a autonomia com cães de proteção, ocupando um espaço necessário e potente no mercado.' },
  { title: 'Simplicidade na Complexidade', text: 'Habilidade rara de traduzir conceitos avançados de adestramento para quem está começando, sem perder a profundidade técnica.' },
];
---

<section id="diferenciais" class="py-16 sm:py-24 lg:py-40 bg-bg relative overflow-hidden" aria-label="Diferenciais do She ForceK9">
  
  <!-- Elemento decorativo de fundo -->
  <div class="absolute top-0 right-0 w-1/3 h-1/2 bg-surface rounded-bl-[10vw] -z-10 opacity-50"></div>

  <div class="container-content">

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 sm:gap-12 items-end mb-12 sm:mb-20 lg:mb-32">
      <div class="lg:col-span-7">
        <SectionHeader
          label="A Diferença SheForce"
          title="8 Princípios da nossa abordagem centrada na mulher"
          align="left"
        />
      </div>
      <div class="lg:col-span-5 pb-10 sm:pb-16 lg:pb-20">
        <p class="font-sans text-[1rem] text-muted leading-relaxed border-l-2 border-gold/30 pl-4 sm:pl-6">
          "Unimos técnica canina, psicologia e direito para entregar uma experiência completa. A proteção real vai muito além do adestramento."
        </p>
      </div>
    </div>

    <!-- Layout Central: Foto e Princípios em volta -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 sm:gap-12 lg:gap-16 items-start">
      
      <!-- Coluna Esquerda (Princípios 1-4) -->
      <div class="lg:col-span-4 space-y-8 sm:space-y-12" id="diferenciais-col-1">
        {itens.slice(0, 4).map((item, i) => (
          <div class="gsap-stagger-item group">
            <div class="flex items-center gap-3 sm:gap-4 mb-2 sm:mb-3">
              <span class="font-display text-xl sm:text-2xl text-gold/40 group-hover:text-gold transition-colors">0{i + 1}</span>
              <h3 class="font-display text-xl sm:text-2xl text-dark uppercase tracking-wide">{item.title}</h3>
            </div>
            <p class="font-sans text-[1rem] text-muted leading-relaxed pl-8 sm:pl-10">
              {item.text}
            </p>
          </div>
        ))}
      </div>

      <!-- Coluna Central (Foto + CTA) -->
      <div class="lg:col-span-4 sticky top-32 flex flex-col gap-32" id="diferenciais-foto-wrapper">
        <div class="relative group">
          <div class="absolute -inset-4 border border-gold/10 rounded-sm translate-x-2 translate-y-2 group-hover:translate-x-0 group-hover:translate-y-0 transition-transform duration-500"></div>
          <div class="aspect-[3/4] bg-surface rounded-sm overflow-hidden shadow-2xl relative z-10">
            <Image
              src={beatrizImage}
              alt="Beatriz Mattos - Instrutora She ForceK9"
              width={400}
              height={533}
              class="w-full h-full object-cover"
            />
            <div class="absolute bottom-0 left-0 right-0 p-6 bg-gradient-to-t from-dark/80 to-transparent">
              <p class="font-sans text-white text-[0.75rem] uppercase tracking-[0.2em] font-bold">Liderança Feminina na Proteção</p>
            </div>
          </div>
        </div>
        <div class="hidden lg:flex justify-center">
          <Button
            label="Fale agora pelo WhatsApp"
            href={whatsappHref}
            variant="gold"
            trackingId="diferenciais-cta"
            section="diferenciais"
          />
        </div>
      </div>

      <!-- Coluna Direita (Princípios 5-7) -->
      <div class="lg:col-span-4 space-y-8 sm:space-y-12" id="diferenciais-col-2">
        {itens.slice(4).map((item, i) => (
          <div class="gsap-stagger-item group">
            <div class="flex items-center gap-4 mb-3">
              <span class="font-display text-2xl text-gold/40 group-hover:text-gold transition-colors">0{i + 5}</span>
              <h3 class="font-display text-xl sm:text-2xl text-dark uppercase tracking-wide">{item.title}</h3>
            </div>
            <p class="font-sans text-[1rem] text-muted leading-relaxed pl-10">
              {item.text}
            </p>
          </div>
        ))}
      </div>

    </div>

    <!-- CTA Mobile apenas -->
    <div class="lg:hidden mt-8 sm:mt-12 pt-4 sm:pt-6 flex justify-center">
      <Button
        label="Fale agora pelo WhatsApp"
        href={whatsappHref}
        variant="gold"
        trackingId="diferenciais-cta"
        section="diferenciais"
      />
    </div>

  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) return;

    gsap.from('.gsap-stagger-item', {
      scrollTrigger: { 
        trigger: '#diferenciais', 
        start: 'top 70%', 
        toggleActions: 'play none none none' 
      },
      opacity: 0, 
      y: 30, 
      duration: 0.8, 
      ease: 'power3.out', 
      stagger: 0.1,
    });

    gsap.from('#diferenciais-foto-wrapper', {
      scrollTrigger: { 
        trigger: '#diferenciais-foto-wrapper', 
        start: 'top 80%' 
      },
      opacity: 0,
      scale: 0.95,
      duration: 1.2,
      ease: 'power2.out'
    });
  });
</script>
