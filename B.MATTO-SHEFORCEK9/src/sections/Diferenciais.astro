---
import SectionHeader from '../components/global/SectionHeader.astro';
import Button from '../components/global/Button.astro';

const whatsappHref = 'https://wa.me/5511918952921?text=Ol%C3%A1!%20Vi%20o%20site%20e%20quero%20saber%20mais.';

const itens = [
  { title: 'Inclusão Total', text: 'Qualquer mulher pode participar — nenhuma experiência prévia é necessária. O curso é desenhado para quem nunca teve contato com adestramento.' },
  { title: 'Sem Limite de Raça', text: 'Qualquer cão é bem-vindo — inclusive pets sem histórico de proteção. Focamos na condução e no vínculo, não apenas na agressão.' },
  { title: 'Conhecimento Jurídico', text: 'Você não aprende só sobre cães — aprende sobre seus direitos, legítima defesa e como agir dentro da lei em situações de risco.' },
  { title: 'Espaço Seguro', text: 'Ambiente exclusivamente feminino, sem julgamentos. Um lugar onde você pode expor seus medos e ser ouvida de verdade.' },
  { title: 'Prática Direta', text: 'Didática clara e prática — sem teorias complicadas ou termos técnicos que só servem para inflar o ego de instrutores.' },
  { title: 'Transparência', text: 'Eu não retenho conhecimento: meu valor está em transmitir tudo o que sei para que você se torne independente.' },
  { title: 'Rede de Apoio', text: 'Grupo de mulheres que segue junto — a rede de apoio começa no curso e se estende para a vida, com treinos e encontros.' },
];
---

<section id="diferenciais" class="py-24 lg:py-40 bg-bg relative overflow-hidden" aria-label="Diferenciais do She ForceK9">
  
  <!-- Elemento decorativo de fundo -->
  <div class="absolute top-0 right-0 w-1/3 h-1/2 bg-surface rounded-bl-[10vw] -z-10 opacity-50"></div>

  <div class="container-content">

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-end mb-20 lg:mb-32">
      <div class="lg:col-span-7">
        <SectionHeader
          label="A Diferença SheForce"
          title="7 Princípios da minha abordagem centrada na mulher"
          align="left"
        />
      </div>
      <div class="lg:col-span-5 pb-16 lg:pb-20">
        <p class="font-sans text-body-lg text-muted leading-relaxed border-l-2 border-gold/30 pl-6 italic">
          "Eu já ocupei todos os papéis: fui cliente, atendi a domicílio, tive escola e hoje sou competidora titulada. Isso me dá uma leitura que une técnica e sensibilidade feminina."
        </p>
      </div>
    </div>

    <!-- Layout Central: Foto e Princípios em volta -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
      
      <!-- Coluna Esquerda (Princípios 1-4) -->
      <div class="lg:col-span-4 space-y-12" id="diferenciais-col-1">
        {itens.slice(0, 4).map((item, i) => (
          <div class="gsap-stagger-item group">
            <div class="flex items-center gap-4 mb-3">
              <span class="font-display text-2xl text-gold/40 group-hover:text-gold transition-colors">0{i + 1}</span>
              <h3 class="font-display text-xl text-dark uppercase tracking-wide">{item.title}</h3>
            </div>
            <p class="font-sans text-body-sm text-muted leading-relaxed pl-10">
              {item.text}
            </p>
          </div>
        ))}
      </div>

      <!-- Coluna Central (Foto) -->
      <div class="lg:col-span-4 sticky top-32" id="diferenciais-foto-wrapper">
        <div class="relative group">
          <div class="absolute -inset-4 border border-gold/10 rounded-sm translate-x-2 translate-y-2 group-hover:translate-x-0 group-hover:translate-y-0 transition-transform duration-500"></div>
          <div class="aspect-[3/4] bg-surface rounded-sm overflow-hidden shadow-2xl relative z-10">
            <!-- Retrato placeholder elegante -->
            <div class="w-full h-full bg-gradient-to-br from-surface to-gold/10 flex items-center justify-center p-12 text-center">
               <p class="font-display text-gold/40 text-lg uppercase tracking-widest leading-relaxed">
                 Beatriz Mattos<br/>
                 <span class="font-sans text-[0.6rem] tracking-[0.3em]">Instrutora She ForceK9</span>
               </p>
            </div>
            <div class="absolute bottom-0 left-0 right-0 p-6 bg-gradient-to-t from-dark/80 to-transparent">
              <p class="font-sans text-white text-[0.7rem] uppercase tracking-[0.2em] font-bold">Liderança Feminina no Adestramento</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Coluna Direita (Princípios 5-7 + CTA) -->
      <div class="lg:col-span-4 space-y-12" id="diferenciais-col-2">
        {itens.slice(4).map((item, i) => (
          <div class="gsap-stagger-item group">
            <div class="flex items-center gap-4 mb-3">
              <span class="font-display text-2xl text-gold/40 group-hover:text-gold transition-colors">0{i + 5}</span>
              <h3 class="font-display text-xl text-dark uppercase tracking-wide">{item.title}</h3>
            </div>
            <p class="font-sans text-body-sm text-muted leading-relaxed pl-10">
              {item.text}
            </p>
          </div>
        ))}

        <div class="pt-12 gsap-stagger-item">
          <Button
            label="Quero agendar uma conversa"
            href={whatsappHref}
            variant="gold"
            trackingId="diferenciais-cta"
            section="diferenciais"
            fullWidth={true}
          />
        </div>
      </div>

    </div>

  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) return;

    gsap.from('.gsap-stagger-item', {
      scrollTrigger: { 
        trigger: '#diferenciais', 
        start: 'top 70%', 
        toggleActions: 'play none none none' 
      },
      opacity: 0, 
      y: 30, 
      duration: 0.8, 
      ease: 'power3.out', 
      stagger: 0.1,
    });

    gsap.from('#diferenciais-foto-wrapper', {
      scrollTrigger: { 
        trigger: '#diferenciais-foto-wrapper', 
        start: 'top 80%' 
      },
      opacity: 0,
      scale: 0.95,
      duration: 1.2,
      ease: 'power2.out'
    });
  });
</script> duration: 0.8, ease: 'power2.out',
    });
  });
</script>
