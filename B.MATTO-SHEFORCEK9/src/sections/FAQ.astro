---
import SectionHeader from '../components/global/SectionHeader.astro';

const perguntas = [
  {
    pergunta: 'Preciso ter experiência com cães ou adestramento?',
    resposta: 'Não. O She ForceK9 foi desenhado para mulheres que estão começando do zero. Você aprenderá tudo o que precisa em um ambiente seguro e controlado.',
  },
  {
    pergunta: 'Meu cão precisa ser de raça específica?',
    resposta: 'Qualquer cão é bem-vindo. Focamos na sua condução e no vínculo. Se o seu cão não for apto para proteção, você praticará com os nossos cães formados.',
  },
  {
    pergunta: 'E se eu não tiver um cão no momento?',
    resposta: 'Você pode participar normalmente. Fornecemos cães treinados para as práticas e ensinamos como escolher o seu futuro parceiro de proteção.',
  },
  {
    pergunta: 'É seguro trabalhar com cães de proteção?',
    resposta: 'Totalmente seguro. Os treinos são supervisionados por profissionais e os cães utilizados são extremamente equilibrados e seguros para iniciantes.',
  },
  {
    pergunta: 'Como funcionam os módulos teóricos?',
    resposta: 'Unimos Direito (limites da lei) e Psicologia (resiliência) para que você tenha não apenas a força do cão, mas a clareza mental para decidir quando agir.',
  },
  {
    pergunta: 'O curso é realmente só para mulheres?',
    description: 'Sim. Criamos um ecossistema exclusivo para que a comunicação seja direta, sem ruídos e focada nas dores e necessidades reais da mulher moderna.',
  },
];
---

<section id="faq" class="py-24 lg:py-40 bg-surface relative overflow-hidden" aria-label="Perguntas frequentes">
  
  <!-- Fundo dinâmico com orbes e padrões -->
  <div class="absolute inset-0 pointer-events-none">
    <!-- Padrão de ruído sutil -->
    <div class="opacity-[0.03]" style="background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E\"); background-size: 200px;"></div>
    <!-- Linha decorativa topo -->
    <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>
    <!-- Orbe embaixo esquerda -->
    <div class="absolute -bottom-20 -left-20 w-80 h-80 bg-gold/5 rounded-full blur-3xl animate-float"></div>
    <!-- Orbe topo direita -->
    <div class="absolute top-1/3 right-0 w-96 h-96 bg-gold/6 rounded-full blur-[120px]" style="animation: float 8s ease-in-out infinite 1s;"></div>
    <!-- Orbe centro -->
    <div class="absolute top-1/2 left-1/3 w-72 h-72 bg-primary/4 rounded-full blur-[100px]" style="animation: float 10s ease-in-out infinite 2s;"></div>
  </div>

  <div class="container-content relative z-10">

    <SectionHeader
      label="Dúvidas Frequentes"
      title="Perguntas frequentes"
      align="center"
    />

    <!-- Accordion Premium -->
    <div class="max-w-3xl mx-auto space-y-4" id="faq-accordion">
      {perguntas.map((item, i) => (
        <div
          class="group border-b border-gold/20 bg-white shadow-sm hover:shadow-xl transition-all duration-500 rounded-sm"
          data-faq-item={i}
        >
          <button
            type="button"
            class="
              w-full flex items-center justify-between gap-6
              px-8 py-6 text-left
              transition-colors duration-300
              focus-visible:outline-none
            "
            aria-expanded="false"
            aria-controls={`faq-answer-${i}`}
            id={`faq-btn-${i}`}
          >
            <span class="font-display text-lg lg:text-xl text-dark group-hover:text-gold transition-colors">{item.pergunta}</span>
            <div class="flex-shrink-0 w-8 h-8 rounded-full border border-gold/20 flex items-center justify-center group-hover:border-gold transition-colors">
              <svg
                width="12" height="12"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                class="faq-icon transition-transform duration-500"
                aria-hidden="true"
              >
                <path d="M6 9l6 6 6-6" />
              </svg>
            </div>
          </button>
          
          <div
            id={`faq-answer-${i}`}
            role="region"
            aria-labelledby={`faq-btn-${i}`}
            class="faq-answer overflow-hidden max-h-0 transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)]"
          >
            <div class="px-8 pb-8">
              <div class="h-px w-12 bg-gold/30 mb-6"></div>
              <p class="font-sans text-body-md text-muted leading-relaxed">
                {item.resposta || item.description}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const items = document.querySelectorAll('[data-faq-item]');

    items.forEach((item) => {
      const btn    = item.querySelector('button');
      const answer = item.querySelector('.faq-answer');
      const icon   = item.querySelector('.faq-icon');
      if (!btn || !answer || !icon) return;

      btn.addEventListener('click', () => {
        const isOpen = btn.getAttribute('aria-expanded') === 'true';

        // Fechar outros (opcional, mas elegante)
        items.forEach((otherItem) => {
          if (otherItem !== item) {
            const otherBtn    = otherItem.querySelector('button');
            const otherAnswer = otherItem.querySelector('.faq-answer');
            if (otherBtn && otherAnswer) {
              otherBtn.setAttribute('aria-expanded', 'false');
              (otherAnswer as HTMLElement).style.maxHeight = '0';
              otherItem.classList.remove('shadow-xl');
            }
          }
        });

        // Toggle este
        if (isOpen) {
          btn.setAttribute('aria-expanded', 'false');
          (answer as HTMLElement).style.maxHeight = '0';
          item.classList.remove('shadow-xl');
        } else {
          btn.setAttribute('aria-expanded', 'true');
          const content = answer.querySelector('div');
          (answer as HTMLElement).style.maxHeight = content ? content.scrollHeight + 32 + 'px' : '1000px';
          item.classList.add('shadow-xl');
        }
      });
    });
  });
</script>
