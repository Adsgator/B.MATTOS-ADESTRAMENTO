---
import Button from '../components/global/Button.astro';
import { Image } from 'astro:assets';
import heroImage from '../assets/images/hero-principal.png';

const whatsappHref = 'https://wa.me/5511918952921?text=Ol%C3%A1!%20Vi%20o%20site%20e%20quero%20saber%20mais.';
---

<!-- Hero full-bleed — fundo escuro com textura, conteúdo 2 colunas no desktop -->
<section
  id="hero-section"
  class="
    relative min-h-[90vh] lg:min-h-screen
    bg-dark overflow-hidden
    flex items-center
  "
  aria-label="Apresentação principal"
>

  <!-- Textura de fundo (grain visual sutil) -->
  <div
    aria-hidden="true"
    class="absolute inset-0 opacity-[0.03] pointer-events-none"
    style="background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E\"); background-size: 200px;"
  ></div>

  <!-- Gradiente de profundidade -->
  <div class="absolute inset-0 bg-gradient-to-t from-dark via-transparent to-transparent opacity-60"></div>

  <!-- Container interno -->
  <div class="container-content relative z-10 w-full pt-32 pb-20 lg:pt-40 lg:pb-32">
    <div class="grid grid-cols-1 lg:grid-cols-[52%_48%] gap-12 lg:gap-16 items-center">

      <!-- Coluna texto -->
      <div class="relative">
        
        <!-- Elemento decorativo sutil -->
        <div class="absolute -top-12 -left-4 w-24 h-24 border-l border-t border-gold/20 opacity-50 hidden lg:block"></div>

        <!-- Label -->
        <div class="flex items-center gap-3 mb-6" id="hero-label">
          <div class="w-8 h-px bg-gold/50"></div>
          <p class="section-label !text-gold/80 !mb-0">
            She ForceK9 · O Único 100% Feminino
          </p>
        </div>

        <!-- H1 -->
        <h1
          class="font-display text-display-2xl text-white mb-8 max-w-2xl"
          id="hero-title"
        >
          Sinta-se segura em qualquer lugar com um <span class="text-gold italic">cão de proteção</span> ao seu lado
        </h1>

        <!-- Subtítulo -->
        <p
          class="font-sans text-body-lg text-white/60 leading-relaxed mb-12 max-w-xl"
          id="hero-subtitle"
        >
          O She ForceK9 é o treinamento presencial pioneiro no Brasil criado exclusivamente para mulheres. Aprenda a conduzir e conviver com um cão de guarda com segurança real e dentro da lei — sem precisar de experiência prévia.
        </p>

        <!-- CTA + Info -->
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6" id="hero-cta">
          <Button
            label="Quero saber mais"
            href={whatsappHref}
            variant="gold"
            trackingId="hero-cta"
            section="hero"
            size="lg"
          />
          
          <div class="flex flex-col gap-1">
            <p class="font-sans text-white font-medium text-body-sm">Próxima Turma: Julho 2026</p>
            <p class="font-sans text-white/40 text-[0.7rem] uppercase tracking-widest">Vagas extremamente limitadas</p>
          </div>
        </div>

        <!-- Badges — estilo premium isomeet -->
        <div class="mt-16 pt-8 border-t border-white/5 flex flex-wrap gap-8 opacity-60" id="hero-badges">
          <div class="flex items-center gap-2">
            <span class="text-gold font-display text-2xl">01.</span>
            <span class="text-white/70 text-label">Presencial em SJC/SP</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-gold font-display text-2xl">02.</span>
            <span class="text-white/70 text-label">Qualquer raça participa</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-gold font-display text-2xl">03.</span>
            <span class="text-white/70 text-label">Foco total na mulher</span>
          </div>
        </div>
      </div>

      <!-- Coluna imagem -->
      <div class="relative lg:pl-8" id="hero-image-wrapper">

        <!-- Frame Decorativo -->
        <div class="absolute -inset-4 border border-gold/10 rounded-sm translate-x-4 translate-y-4 hidden lg:block"></div>

        <!-- Imagem Principal -->
        <div
          class="
            relative w-full aspect-[4/5] rounded shadow-2xl overflow-hidden
            border border-white/10
          "
        >
          <Image
            src={heroImage}
            alt="Mulher confiante caminhando com seu cão de proteção em ambiente urbano"
            width={800}
            height={1000}
            loading="eager"
            fetchpriority="high"
            class="w-full h-full object-cover grayscale-[0.2] hover:grayscale-0 transition-all duration-700"
          />
          
          <!-- Overlay Soft -->
          <div class="absolute inset-0 bg-gradient-to-t from-dark/60 via-transparent to-transparent"></div>

          <!-- Badge Flutuante 1 -->
          <div
            class="
              absolute top-8 -left-6
              bg-dark/90 backdrop-blur-md border border-white/10
              rounded-sm px-6 py-4
              shadow-2xl
            "
            id="hero-detail-card-1"
          >
            <p class="font-display text-gold text-lg leading-tight">Segurança<br/>Real</p>
            <p class="font-sans text-white/40 text-[0.6rem] uppercase mt-2 tracking-widest">Certificado SheForce</p>
          </div>

          <!-- Badge Flutuante 2 -->
          <div
            class="
              absolute bottom-12 -right-6
              bg-gold-gradient
              rounded-sm px-6 py-4
              shadow-2xl
            "
            id="hero-detail-card-2"
          >
            <p class="font-sans text-white font-bold text-body-sm leading-tight uppercase tracking-wider">Metodologia<br/>Beatriz Mattos</p>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 opacity-40 group cursor-pointer" aria-hidden="true">
    <span class="font-sans text-[0.6rem] text-white uppercase tracking-[0.3em] group-hover:text-gold transition-colors">Descobrir</span>
    <div class="w-px h-10 bg-gradient-to-b from-gold to-transparent"></div>
  </div>
</section>

<style>
  @keyframes scroll-line {
    0%   { transform: translateY(-100%); }
    100% { transform: translateY(400%); }
  }
</style>

<script>
  // Animações do Hero com GSAP
  document.addEventListener('DOMContentLoaded', () => {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) return;

    const tl = gsap.timeline({ defaults: { ease: 'power2.out' } });

    tl
      .from('#hero-label',    { opacity: 0, y: 20, duration: 0.6 }, 0.2)
      .from('#hero-title',    { opacity: 0, y: 40, duration: 0.8 }, 0.4)
      .from('#hero-subtitle', { opacity: 0, y: 30, duration: 0.7 }, 0.6)
      .from('#hero-badges > *', {
        opacity: 0, y: 15, duration: 0.5, stagger: 0.1
      }, 0.8)
      .from('#hero-cta',      { opacity: 0, y: 20, duration: 0.5 }, 1.0)
      .from('#hero-image-wrapper', { opacity: 0, x: 40, duration: 0.9 }, 0.5)
      .from('#hero-detail-card-1', { opacity: 0, x: 20, duration: 0.5 }, 1.1)
      .from('#hero-detail-card-2', { opacity: 0, x: -20, duration: 0.5 }, 1.2);
  });
</script>
