---
import SectionHeader from '../components/global/SectionHeader.astro';
import InstagramFeed from '../components/islands/InstagramFeed';
---

<section id="instagram" class="py-24 lg:py-40 bg-bg" aria-label="Feed do Instagram">

  <!-- Header com título -->
  <div class="container-content mb-16 lg:mb-20">
    <SectionHeader
      label="No Instagram"
      title="Veja o que acontece na prática"
      subtitle="Conteúdo novo toda semana — acompanhe as atualizações e treinos."
      align="center"
    />
  </div>

  <!-- Grid Full-width dos posts -->
  <div class="w-full px-4 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <!-- Island React — client:visible para não bloquear carregamento -->
      <InstagramFeed
        client:visible
        username="abeak9"
        profileUrl="https://www.instagram.com/abeak9"
      />
    </div>
  </div>

</section>
