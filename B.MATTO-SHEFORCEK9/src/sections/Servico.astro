---
import SectionHeader from '../components/global/SectionHeader.astro';
import Button from '../components/global/Button.astro';

const whatsappHref = 'https://wa.me/5511918952921?text=Ol%C3%A1!%20Vi%20o%20site%20e%20quero%20saber%20mais.';

const itens = [
  { icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title: 'Imersão Presencial', text: 'Quatro dias intensos em São José dos Campos, com foco total na prática.' },
  { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', title: 'Prática Segura', text: 'Trabalho direto com cães de proteção formados, sob supervisão profissional.' },
  { icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z', title: 'Suporte Psicológico', text: 'Dinâmicas focadas no empoderamento e superação de traumas e inseguranças.' },
  { icon: 'M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3', title: 'Amparo Jurídico', text: 'Entenda os limites da legítima defesa com cães no cenário legal brasileiro.' },
  { icon: 'M21 15.546c-.523 0-1.046.151-1.5.454a2.704 2.704 0 01-3 0 2.704 2.704 0 00-3 0 2.704 2.704 0 01-3 0 2.704 2.704 0 00-3 0 2.704 2.704 0 01-3 0 2.704 2.704 0 00-1.5-.454M9 6v2m3-2v2m3-2v2M9 3h.01M12 3h.01M15 3h.01M21 21v-7a2 2 0 00-2-2H5a2 2 0 00-2 2v7h18zm-3-9v-2a2 2 0 00-2-2H8a2 2 0 00-2 2v2h12z', title: 'Experiência Completa', text: 'Alimentação inclusa em ambiente acolhedor, focado na troca entre mulheres.' },
  { icon: 'M4 6h16M4 10h16M4 14h16M4 18h16', title: 'Abertura para Todos', text: 'Qualquer mulher e qualquer raça de cão são bem-vindas no nosso ecossistema.' },
];
---

<section id="servico" class="py-24 lg:py-40 bg-bg relative overflow-hidden" aria-label="O que é o She ForceK9">
  
  <div class="container-content relative">
    <!-- Decoração lateral -->
    <div class="absolute -left-20 top-0 w-64 h-64 bg-gold/5 rounded-full blur-[100px] pointer-events-none"></div>

    <div class="max-w-4xl mx-auto text-center mb-20 lg:mb-32">
      <SectionHeader
        label="A Experiência"
        title="O She ForceK9 é o seu próximo passo rumo à liberdade"
        subtitle="Quatro dias de imersão onde você aprende a andar na rua sem medo. Unimos técnica canina, amparo jurídico e suporte psicológico em um formato inédito no Brasil."
      />
    </div>

    <!-- Grid de itens Premium -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-20" id="servico-grid">
      {itens.map(({ icon, title, text }, i) => (
        <div
          class="
            gsap-stagger-item
            flex flex-col gap-6 p-10
            bg-white border border-gold/10 rounded-sm
            transition-all duration-500 hover:shadow-2xl hover:-translate-y-2
            relative overflow-hidden group
          "
          data-index={i}
        >
          <!-- Efeito de hover decorativo -->
          <div class="absolute top-0 right-0 w-24 h-24 bg-gold/5 rounded-bl-full translate-x-8 -translate-y-8 group-hover:translate-x-4 group-hover:-translate-y-4 transition-transform duration-500"></div>

          <div class="flex-shrink-0 w-12 h-12 rounded-full bg-gold/10 flex items-center justify-center text-gold group-hover:bg-gold group-hover:text-white transition-all duration-500">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={icon} />
            </svg>
          </div>
          
          <div>
            <h3 class="font-display text-xl text-dark mb-3 uppercase tracking-wide group-hover:text-gold transition-colors">{title}</h3>
            <p class="font-sans text-body-sm text-muted leading-relaxed">
              {text}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="flex flex-col items-center gap-6">
      <Button
        label="Quero garantir minha vaga"
        href={whatsappHref}
        variant="gold"
        trackingId="servico-cta"
        section="servico"
        size="lg"
      />
      <p class="font-sans text-label text-muted/60 uppercase tracking-[0.2em]">Últimas vagas para a turma de Julho</p>
    </div>

  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) return;

    gsap.from('#servico-grid .gsap-stagger-item', {
      scrollTrigger: { trigger: '#servico-grid', start: 'top 85%', toggleActions: 'play none none none' },
      opacity: 0, y: 40, duration: 0.8, ease: 'power3.out', stagger: 0.1,
    });
  });
</script>
