---
import SectionHeader from '../components/global/SectionHeader.astro';
import Button from '../components/global/Button.astro';

const whatsappHref = 'https://wa.me/5511918952921?text=Oi%2C%20vi%20voc%C3%AA%20no%20Google%20e%20gostaria%20de%20saber%20mais%20sobre%20o%20curso%20She%20ForceK9';
---

<section id="servico" class="py-16 sm:py-24 lg:py-40 bg-bg relative overflow-hidden" aria-label="O que é o She ForceK9">
  
  <div class="container-content relative">
    <!-- Decoração lateral -->
    <div class="absolute -left-20 top-0 w-64 h-64 bg-gold/5 rounded-full blur-[100px] pointer-events-none"></div>

    <div class="max-w-4xl mx-auto text-center mb-10 sm:mb-16 lg:mb-20">
      <SectionHeader
        label="A Experiência"
        title="O She ForceK9 é o seu próximo passo rumo à liberdade"
        subtitle="Quatro dias de curso onde você aprende a andar na rua sem medo. Unimos técnica canina, amparo jurídico e suporte psicológico em um formato inédito no Brasil."
      />
    </div>

    <!-- Destaques do Curso -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6 lg:gap-8 mb-10 sm:mb-16 lg:mb-20" id="curso-highlights">
      <div class="group flex flex-col gap-3 sm:gap-6 p-6 sm:p-10 bg-white border border-gold/10 rounded-sm transition-all duration-500 hover:shadow-2xl hover:-translate-y-2 relative overflow-hidden">
        <!-- Efeito decorativo hover -->
        <div class="absolute top-0 right-0 w-24 h-24 bg-gold/5 rounded-bl-full translate-x-8 -translate-y-8 group-hover:translate-x-4 group-hover:-translate-y-4 transition-transform duration-500"></div>

        <div class="flex-shrink-0 w-10 sm:w-12 h-10 sm:h-12 rounded-full bg-gold/10 flex items-center justify-center text-gold group-hover:bg-gold group-hover:text-white transition-all duration-500">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="sm:w-6 sm:h-6">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
        </div>

        <div>
          <h3 class="font-display text-xl sm:text-2xl text-dark mb-2 sm:mb-3 uppercase tracking-wide group-hover:text-gold transition-colors">4 Dias</h3>
          <p class="font-sans text-[1rem] text-muted leading-relaxed">Curso presencial intensivo de 9 a 12 de julho, com foco total na prática e no desenvolvimento contínuo de suas habilidades.</p>
        </div>
      </div>

      <div class="group flex flex-col gap-3 sm:gap-6 p-6 sm:p-10 bg-white border border-gold/10 rounded-sm transition-all duration-500 hover:shadow-2xl hover:-translate-y-2 relative overflow-hidden">
        <!-- Efeito decorativo hover -->
        <div class="absolute top-0 right-0 w-24 h-24 bg-gold/5 rounded-bl-full translate-x-8 -translate-y-8 group-hover:translate-x-4 group-hover:-translate-y-4 transition-transform duration-500"></div>

        <div class="flex-shrink-0 w-10 sm:w-12 h-10 sm:h-12 rounded-full bg-gold/10 flex items-center justify-center text-gold group-hover:bg-gold group-hover:text-white transition-all duration-500">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="sm:w-6 sm:h-6">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          </svg>
        </div>

        <div>
          <h3 class="font-display text-xl text-dark mb-3 uppercase tracking-wide group-hover:text-gold transition-colors">100% Prático</h3>
          <p class="font-sans text-[1rem] text-muted leading-relaxed">Trabalho direto com cães de proteção formados e experientes, sob supervisão profissional constante para garantir sua segurança.</p>
        </div>
      </div>

      <div class="group flex flex-col gap-3 sm:gap-6 p-6 sm:p-10 bg-white border border-gold/10 rounded-sm transition-all duration-500 hover:shadow-2xl hover:-translate-y-2 relative overflow-hidden">
        <!-- Efeito decorativo hover -->
        <div class="absolute top-0 right-0 w-24 h-24 bg-gold/5 rounded-bl-full translate-x-8 -translate-y-8 group-hover:translate-x-4 group-hover:-translate-y-4 transition-transform duration-500"></div>

        <div class="flex-shrink-0 w-10 sm:w-12 h-10 sm:h-12 rounded-full bg-gold/10 flex items-center justify-center text-gold group-hover:bg-gold group-hover:text-white transition-all duration-500">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="sm:w-6 sm:h-6">
            <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M23 21v-2a4 4 0 00-3-3.87"></path>
            <path d="M16 3.13a4 4 0 010 7.75"></path>
          </svg>
        </div>

        <div>
          <h3 class="font-display text-xl text-dark mb-3 uppercase tracking-wide group-hover:text-gold transition-colors">Só Mulheres</h3>
          <p class="font-sans text-[1rem] text-muted leading-relaxed">Ecossistema exclusivo e seguro onde a comunicação é direta, focada nas necessidades reais e experiências da mulher moderna.</p>
        </div>
      </div>
    </div>


    <!-- CTA -->
    <div class="flex flex-col items-center gap-6">
      <Button
        label="Quero garantir minha vaga"
        href={whatsappHref}
        variant="gold"
        trackingId="servico-cta"
        section="servico"
        size="lg"
      />
      <p class="font-sans text-label text-muted/60 uppercase tracking-[0.2em]">Últimas vagas para a turma de Julho</p>
    </div>

  </div>
</section>

