---
import Button from '../components/global/Button.astro';

const whatsappHref = 'https://wa.me/5511918952921?text=Ol%C3%A1!%20Vi%20o%20site%20e%20quero%20saber%20mais.';
---

<section
  id="cta-final"
  class="relative py-32 lg:py-48 bg-dark overflow-hidden"
  aria-label="Garantir vaga"
>

  <!-- Gradiente de Fundo Premium -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-gold/5 via-dark to-dark opacity-80"></div>
  
  <!-- Acentos decorativos -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-px bg-gradient-to-r from-transparent via-gold/20 to-transparent"></div>

  <div class="container-content relative z-10 text-center max-w-4xl mx-auto" id="cta-final-content">

    <div class="inline-flex items-center gap-4 mb-8">
      <div class="w-12 h-px bg-gold/30"></div>
      <p class="section-label !text-gold !mb-0 tracking-[0.4em]">Inscrições Abertas</p>
      <div class="w-12 h-px bg-gold/30"></div>
    </div>

    <h2 class="font-display text-display-xl text-white mb-10">
      Não espere a insegurança bater à sua porta para agir. <span class="text-gold">Seja a proteção</span>.
    </h2>

    <p class="font-sans text-body-lg text-white/60 leading-relaxed mb-14 max-w-2xl mx-auto">
      O She ForceK9 é uma experiência transformadora que mudará sua relação com o medo. As turmas são limitadas para garantir que cada mulher receba a atenção necessária.
    </p>

    <div class="flex flex-col items-center gap-6">
      <Button
        label="Quero minha vaga na turma de Julho"
        href={whatsappHref}
        variant="gold"
        trackingId="cta-final"
        section="cta-final"
        size="lg"
      />
      
      <div class="flex items-center gap-2 text-white/40 text-label uppercase tracking-widest">
        <span class="w-2 h-2 rounded-full bg-gold animate-pulse"></span>
        Restam apenas 4 vagas disponíveis
      </div>
    </div>

  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) return;

    gsap.from('#cta-final-content > *', {
      scrollTrigger: { trigger: '#cta-final', start: 'top 80%', toggleActions: 'play none none none' },
      opacity: 0, y: 30, duration: 1, ease: 'power3.out', stagger: 0.15,
    });
  });
</script>
