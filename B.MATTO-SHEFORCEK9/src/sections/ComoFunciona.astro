---
import SectionHeader from '../components/global/SectionHeader.astro';
import Button from '../components/global/Button.astro';

const whatsappHref = 'https://wa.me/5511918952921?text=Oi%2C%20vi%20voc%C3%AA%20no%20Google%20e%20gostaria%20de%20saber%20mais%20sobre%20o%20curso%20She%20ForceK9';

const modulos = [
  {
    grupo: 'Fundamentos Caninos',
    desc: 'O entendimento profundo do bicho.',
    itens: [
      'Análise do comportamento canino real',
      'Comunicação limpa em ambiente urbano',
      'Técnicas de condução segura',
      'Diferenciais da proteção feminina',
      'Figuração e formação técnica',
      'Como selecionar o cão ideal',
    ],
  },
  {
    grupo: 'Pilar Humano',
    desc: 'Onde a técnica encontra a mulher.',
    itens: [
      'Psicologia: dinâmicas de suporte',
      'Resiliência e empoderamento real',
      'Direito: limites da legítima defesa',
      'Cães de proteção e a lei brasileira',
      'Condução sob estresse extremo',
      'Vínculo e convivência diária',
    ],
  },
];
---

<section id="como-funciona" class="py-16 sm:py-24 lg:py-40 bg-surface relative overflow-hidden" aria-label="O que você vai aprender">

  <!-- Fundo decorativo: orbes e gradientes -->
  <div class="absolute inset-0 pointer-events-none">
    <!-- Orbe 1 - topo esquerda -->
    <div class="absolute -top-40 -left-40 w-80 h-80 bg-gold/5 rounded-full blur-[120px] animate-float"></div>
    <!-- Orbe 2 - topo direita -->
    <div class="absolute -top-60 right-0 w-96 h-96 bg-primary/3 rounded-full blur-[140px]" style="animation: float 8s ease-in-out infinite 1s;"></div>
    <!-- Orbe 3 - embaixo -->
    <div class="absolute bottom-0 left-1/4 w-72 h-72 bg-gold/4 rounded-full blur-[100px]" style="animation: float 10s ease-in-out infinite 2s;"></div>
    <!-- Grid sutil -->
    <div class="absolute inset-0 opacity-[0.02] pointer-events-none" style="background-image: linear-gradient(0deg, rgba(255,77,0,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,77,0,0.1) 1px, transparent 1px); background-size: 50px 50px;"></div>
  </div>

  <!-- Detalhe decorativo -->
  <div class="absolute left-0 bottom-0 w-full h-1/4 bg-gradient-to-t from-bg to-transparent opacity-50"></div>

  <div class="container-content relative z-10">

    <div class="max-w-4xl mb-12 sm:mb-20">
      <SectionHeader
        label="O Método"
        title="O que você vai aprender: o equilíbrio entre técnica e sensibilidade"
        subtitle="O curso é dividido em dois grandes pilares que se fundem durante os quatro dias de curso presencial."
        align="left"
      />
    </div>

    <!-- Layout de Cards Editorial -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 sm:gap-12 lg:gap-20" id="como-funciona-grid">

      {modulos.map(({ grupo, desc, itens }, gi) => (
        <div class="gsap-reveal flex flex-col">
          
          <div class="flex items-baseline gap-3 sm:gap-4 mb-6 sm:mb-8">
            <span class="font-display text-3xl sm:text-4xl lg:text-5xl text-gold/20 leading-none">0{gi + 1}</span>
            <div>
              <h3 class="font-display text-xl sm:text-2xl text-dark uppercase tracking-wide">{grupo}</h3>
              <p class="font-sans text-[1rem] text-muted">{desc}</p>
            </div>
          </div>

          <div class="grid grid-cols-1 gap-2 sm:gap-4">
            {itens.map((item) => (
              <div class="group flex items-center justify-between p-3 sm:p-5 bg-white/50 border border-dark/5 rounded-sm hover:bg-white hover:shadow-xl hover:border-gold/30 transition-all duration-300">
                <p class="font-sans text-[1rem] text-dark/80 group-hover:text-dark transition-colors">{item}</p>
                <div class="w-2 h-2 rounded-full bg-gold/30 group-hover:bg-gold transition-colors"></div>
              </div>
            ))}
          </div>
        </div>
      ))}

    </div>

    <!-- CTA Area -->
    <div class="mt-16 sm:mt-24 pt-12 sm:pt-20 border-t border-dark/5 flex flex-col items-center text-center">
      <h4 class="font-display text-display-md text-dark mb-4 sm:mb-8 max-w-2xl text-xl sm:text-2xl">
        Mais do que um curso de adestramento, é um resgate da sua <span class="text-gold">autonomia</span>.
      </h4>
      <Button
        label="Fale agora pelo WhatsApp"
        href={whatsappHref}
        variant="gold"
        trackingId="como-funciona-cta"
        section="como-funciona"
        size="lg"
      />
    </div>

  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) return;

    gsap.from('.gsap-reveal', {
      scrollTrigger: { 
        trigger: '#como-funciona-grid', 
        start: 'top 75%' 
      },
      opacity: 0,
      x: (i) => i === 0 ? -30 : 30,
      duration: 1,
      ease: 'power3.out',
      stagger: 0.2
    });
  });
</script>
