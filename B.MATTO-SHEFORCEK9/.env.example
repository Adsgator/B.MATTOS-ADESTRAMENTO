# SheForceK9 — Configuração de Variáveis de Ambiente
# ═════════════════════════════════════════════════════════════════════════════

# ANALYTICS & TRACKING
# Obter em: https://tagmanager.google.com/
GTM_ID=GTM-XXXXXXX

# CONTATO & COMUNICAÇÃO
# WhatsApp — formato DDI + DDD + número, sem espaços ou símbolos
WHATSAPP_NUMBER=5511918952921

# Mensagem pré-preenchida URL-encoded (será anexada ao link WhatsApp)
WHATSAPP_MESSAGE=Ol%C3%A1!%20Vi%20o%20site%20e%20quero%20saber%20mais.%20Gostaria%20de%20conhecer%20mais%20sobre%20o%20She%20ForceK9

# FORMULÁRIOS & INTEGRAÇÕES
# Web3Forms — para formulário de contato (opcional)
# Obter em: https://web3forms.com/
ACCESS_KEY=

# INSTAGRAM
# Token da Graph API — para feed dinâmico (opcional)
# Obter em: https://developers.facebook.com/tools/explorer/
INSTAGRAM_TOKEN=

# MAPS
# Google Maps API Key — para embed avançado (opcional)
# Obter em: https://developers.google.com/maps
GOOGLE_MAPS_API_KEY=

# STRIPE / GATEWAY DE PAGAMENTO (quando confirmado)
# Se usando Stripe:
# PUBLIC_STRIPE_KEY=pk_test_...
# SECRET_STRIPE_KEY=sk_test_...
# Obter em: https://dashboard.stripe.com/apikeys

# Se usando outro gateway, adicione as variáveis aqui

# SITE
# Domínio canônico — atualizar conforme ambiente
SITE_URL=https://sheforcek9.abeak9adestramento.com.br

# Ambiente
PUBLIC_ENV=production
