---
// src/sections/HeroSection.astro
import { Image } from 'astro:assets';
import Button from '../components/Button.astro';
import heroImage from '../assets/images/hero-principal.webp';

const wppUrl =
  'https://wa.me/5511918952921?text=Ol%C3%A1%2C%20Beatriz!%20Vi%20o%20site%20e%20quero%20saber%20mais%20sobre%20a%20mentoria.%20Seguem%20minhas%20informa%C3%A7%C3%B5es%3A%20Ra%C3%A7a%3A%20%7C%20Idade%20do%20c%C3%A3o%3A%20%7C%20Principal%20problema%20comportamental%3A%20%7C%20Hist%C3%B3rico%20de%20adestramento%3A%20%7C%20Estou%20disposto%20a%20mudar%20a%20rotina%3A';
---

<section
  id="hero"
  class="bg-background pt-24 pb-0 xl:pt-32 xl:pb-0 px-5 xl:px-12 relative"
>
  <!-- Dot pattern background -->
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none select-none" style="background-image: radial-gradient(circle, currentColor 1px, transparent 1px); background-size: 32px 32px;"></div>

  <!-- Accent glow behind image area -->
  <div class="hidden xl:block absolute right-0 top-1/2 -translate-y-1/3 w-[500px] h-[500px] bg-accent/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-w-content mx-auto relative z-10">
    <div class="flex flex-col gap-12 xl:gap-20">
      
      <div class="max-w-[1000px]">
        <h1 class="font-display text-h1 text-foreground leading-[0.85] uppercase">
          LIDERANÇA E DISCIPLINA <br/>
          <span class="text-accent">COM PRECISÃO TÁTICA.</span>
        </h1>
        
        <div class="relative inline-block mt-12 xl:mt-4">
          <span class="xl:absolute xl:-top-6 xl:left-[60%] font-hand text-hand-lg text-accent rotate-[-4deg] whitespace-nowrap bg-background px-4 py-1 border-2 border-foreground shadow-card z-20">
            fale a língua do seu cão
          </span>
        </div>
      </div>

      <div class="flex flex-col xl:grid xl:grid-cols-[1fr_420px] gap-12 xl:items-end">
        <div class="flex flex-col gap-6 xl:max-w-[600px] xl:pb-24">
          <p class="font-display text-h3 text-foreground/80 uppercase">
            Ajuste sua comunicação e recupere <br class="hidden xl:block"/>
            a clareza na convivência com o seu cão.
          </p>

          <!-- Mobile-only image -->
          <div class="hero-image-animate block xl:hidden relative my-4 group cursor-crosshair">
            <Image
              src={heroImage}
              alt="Beatriz Mattos em treinamento com American Bully"
              width={600}
              height={600}
              loading="eager"
              format="webp"
              class="w-full max-w-[320px] mx-auto drop-shadow-xl grayscale contrast-125 brightness-90 group-hover:grayscale-0 transition-all duration-700 img-fade-bottom"
            />
            <div class="absolute bottom-4 left-4 bg-foreground text-accent px-4 py-2 font-display text-label tracking-[0.2em] border-2 border-accent shadow-card">
              MENTORIA INDIVIDUAL
            </div>
          </div>
          
          <p class="font-sans text-body-lg text-muted-foreground">
            A mentoria individual foca no ponto central que é a sua postura como condutor do cão. Através de uma análise técnica e personalizada identificamos as falhas na sua comunicação que geram desobediência e insegurança.
          </p>

          <p class="font-sans text-body text-foreground font-bold border-l-4 border-accent pl-6 bg-surface py-4">
            Desenvolva a clareza técnica para lidar com o seu cão no dia a dia construindo resultados consistentes e independência real.
          </p>

          <div id="hero-ctas" class="flex flex-col sm:flex-row items-center gap-8 mt-4">
            <Button
              label="QUERO LIDERAR MEU CÃO"
              href={wppUrl}
              variant="accent"
              trackingId="btn-cta-hero"
              section="hero"
              newTab={true}
              class="px-12 py-6 tracking-widest shadow-card"
            />
            <a href="#como-funciona" class="inline-flex items-center justify-center font-display text-body-lg tracking-widest hover:text-accent transition-colors underline underline-offset-8 leading-none">
              VER MEU MÉTODO
            </a>
          </div>
        </div>

        <!-- Floating hero image — overflows section bottom (Desktop only) -->
        <div id="hero-image-wrapper" class="hero-image-animate hidden xl:block relative xl:mb-[-80px] xl:-mr-4 z-20 group cursor-crosshair">
          <!-- Shadow anchor / ground effect -->
          <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[60%] h-[20px] bg-foreground/8 rounded-[50%] blur-xl pointer-events-none hero-shadow"></div>
          
          <Image
            src={heroImage}
            alt="Beatriz Mattos em treinamento com American Bully"
            width={840}
            height={840}
            loading="eager"
            format="webp"
            class="w-full max-w-[380px] mx-auto xl:max-w-[420px] drop-shadow-2xl grayscale contrast-125 brightness-90 group-hover:grayscale-0 transition-all duration-700 img-fade-bottom"
          />

          <!-- Badge label -->
          <div class="absolute bottom-16 xl:bottom-[110px] left-4 xl:left-0 bg-foreground text-accent px-5 py-3 font-display text-label tracking-[0.2em] border-2 border-accent shadow-card">
            MENTORIA INDIVIDUAL
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom gradient fade into next section -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-background to-transparent pointer-events-none z-30"></div>
</section>

<style>
  /* Ensure the overflow is visible beyond the hero section */
  #hero {
    overflow: visible !important;
  }

  /* Fade mask for the image bottom */
  .img-fade-bottom {
    mask-image: linear-gradient(to bottom, black 80%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 80%, transparent 100%);
  }

  /* Subtle floating animation */
  @keyframes heroFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  #hero-image-wrapper {
    animation: heroFloat 6s ease-in-out infinite;
    animation-play-state: paused;
  }

  /* Only float on desktop for performance */
  @media (min-width: 1280px) {
    #hero-image-wrapper {
      animation-play-state: running;
    }
  }

  /* Shadow pulses with float */
  @keyframes shadowPulse {
    0%, 100% { transform: translateX(-50%) scale(1); opacity: 0.1; }
    50% { transform: translateX(-50%) scale(0.9); opacity: 0.06; }
  }

  .hero-shadow {
    animation: shadowPulse 6s ease-in-out infinite;
  }

  @media (min-width: 1280px) {
    .hero-shadow {
      animation-play-state: running;
    }
  }
</style>

<script>
  import gsap from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const tl = gsap.timeline();

    tl.from('#hero h1', { y: 30, duration: 0.7, ease: 'power3.out' })
      .from('#hero .font-hand', { scale: 0, rotation: 10, duration: 0.5, ease: 'back.out(1.7)' }, '-=0.3')
      .from('#hero p', { y: 15, duration: 0.5, stagger: 0.1, ease: 'power2.out' }, '-=0.3')
      .from('#hero-ctas', { y: 20, opacity: 0, duration: 0.6, ease: 'power3.out' }, '-=0.3')
      .from('.hero-image-animate', { y: 60, opacity: 0, scale: 0.95, duration: 1, ease: 'power3.out' }, '-=0.8');
  });
</script>
