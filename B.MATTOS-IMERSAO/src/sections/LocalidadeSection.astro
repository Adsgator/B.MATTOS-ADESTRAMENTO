---
import { Image } from 'astro:assets';
import imgLocalizacao01 from '@/assets/images/img-localizacao-01.webp';
import imgLocalizacao02 from '@/assets/images/img-localizacao-02.webp';
import imgLocalizacao03 from '@/assets/images/img-localizacao-03.webp';
import imgLocalizacao04 from '@/assets/images/img-localizacao-04.webp';
import imgLocalizacao05 from '@/assets/images/img-localizacao-05.webp';

const WA_LINK =
  'https://wa.me/5511918952921?text=Oi%2C%20vi%20voc%C3%AA%20no%20Google%20e%20gostaria%20de%20saber%20mais%20sobre%20a%20imers%C3%A3o%20Training%20Camping';

const localizacaoImages = [imgLocalizacao01, imgLocalizacao02, imgLocalizacao03, imgLocalizacao04, imgLocalizacao05];

const caracteristicas = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18v12H3z"/><path d="M3 6l3-3h12l3 3M6 6v3M18 6v3M9 6v3M15 6v3M3 12h18M3 18h18"/></svg>`,
    title: 'Ambiente controlado',
    description: 'Espaços projetados especificamente para trabalho comportamental com segurança e conforto.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    title: 'Hospedagem incluída',
    description: 'Você se hospeda na chácara junto com seu cão durante toda a imersão.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/><path d="M8 12h8M12 8v8"/></svg>`,
    title: 'Áreas de descompressão',
    description: 'Espaços tranquilos para o cão e para você descansar durante os treinamentos.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h12M3 6h18M3 10h18M3 14h18M3 18h18M3 22h18"/></svg>`,
    title: 'Estrutura completa',
    description: 'Tudo que você precisa para uma imersão focada e sem distrações desnecessárias.',
  },
];
---

<section
  id="localidade"
  class="bg-surface overflow-hidden"
  aria-labelledby="localidade-titulo"
  data-section="localidade"
>
  <!-- Top border -->
  <div class="h-px bg-border"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-16 sm:py-24 lg:py-32">

    <!-- Header -->
    <div class="max-w-3xl mx-auto mb-16 text-center">
      <span class="localidade-reveal inline-block font-sans font-semibold text-xs tracking-[0.2em] uppercase text-secondary mb-3">
        Onde acontece
      </span>
      <h2
        id="localidade-titulo"
        class="localidade-reveal font-display font-bold text-3xl sm:text-4xl lg:text-[2.6rem] text-text-main leading-[1.1] tracking-[0.025em] mb-6"
      >
        Chácara Recanto Feliz
      </h2>
      <p class="localidade-reveal font-sans text-base sm:text-lg text-text-support leading-relaxed">
        Um espaço acolhedor em SJC, pensado para acolher você e seu cão durante a imersão.
      </p>
    </div>

    <!-- Carousel de imagens -->
    <div class="localidade-reveal mb-16 rounded-lg overflow-hidden border border-border" id="localizacao-carousel">
      <div class="relative w-full" style="aspect-ratio: 16/9;">
        <!-- Slides -->
        <div class="relative w-full h-full overflow-hidden">
          {localizacaoImages.map((img, i) => (
            <div
              class="localizacao-slide absolute inset-0 transition-opacity duration-500"
              style={`opacity: ${i === 0 ? '1' : '0'};`}
              data-index={i}
            >
              <Image
                src={img}
                alt={`Chácara Recanto Feliz - Foto ${i + 1}`}
                fill
                class="w-full h-full object-cover"
              />
            </div>
          ))}
        </div>

      </div>
    </div>

    <!-- Características grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 lg:gap-8 mb-16">
      {caracteristicas.map((item) => (
        <div class="localidade-card p-6 border border-border rounded bg-background hover:shadow-md transition-all duration-200">
          <div
            class="w-12 h-12 rounded-lg bg-secondary/10 flex items-center justify-center text-secondary mb-5"
            aria-hidden="true"
            set:html={item.icon}
          />
          <h3 class="font-sans font-semibold text-sm uppercase text-text-main mb-2 leading-snug">
            {item.title}
          </h3>
          <p class="font-sans text-sm text-text-support leading-relaxed">
            {item.description}
          </p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="localidade-reveal flex justify-center mt-14">
      <a
        href={WA_LINK}
        id="btn-localidade"
        data-tracking="click-whatsapp-localidade"
        data-section="localidade"
        rel="noopener noreferrer"
        target="_blank"
        class="inline-flex items-center gap-3 bg-primary text-background font-sans font-semibold text-base px-8 py-4 rounded transition-transform duration-150 hover:scale-[1.03] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
        aria-label="Quero conhecer melhor — abre WhatsApp"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
        </svg>
        Quero conhecer melhor
      </a>
    </div>

  </div>
</section>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Carousel logic
  const carousel = document.getElementById('localizacao-carousel');
  const slides = document.querySelectorAll('.localizacao-slide');
  const dots = document.querySelectorAll('.localizacao-dot');
  let currentIndex = 0;
  let autoplayTimer: NodeJS.Timeout;

  function showSlide(index: number) {
    slides.forEach((slide, i) => {
      (slide as HTMLElement).style.opacity = i === index ? '1' : '0';
    });
    dots.forEach((dot, i) => {
      (dot as HTMLElement).style.opacity = i === index ? '1' : '0.4';
    });
    currentIndex = index;
  }

  function nextSlide() {
    currentIndex = (currentIndex + 1) % slides.length;
    showSlide(currentIndex);
  }

  function autoplay() {
    autoplayTimer = setInterval(nextSlide, 4000);
  }

  // Dot click handlers
  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      clearInterval(autoplayTimer);
      showSlide(i);
      autoplay();
    });
  });

  // Carousel mouse events
  if (carousel) {
    carousel.addEventListener('mouseenter', () => clearInterval(autoplayTimer));
    carousel.addEventListener('mouseleave', () => autoplay());
  }

  // Start autoplay
  autoplay();

  if (!prefersReduced) {
    gsap.utils.toArray<HTMLElement>('.localidade-reveal').forEach((el) => {
      gsap.from(el, {
        opacity: 0,
        y: 30,
        duration: 0.6,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 85%',
          toggleActions: 'play none none none',
        },
      });
    });
  }
</script>
