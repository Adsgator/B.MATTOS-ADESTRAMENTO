---
import { Image } from 'astro:assets';
import logoTrainingCamping from '@/assets/images/logo-training-camping-azul.svg';
import assinaturaAdsgator from '@/assets/assinatura-adsgator-fundo-escuro.svg';

const currentYear = new Date().getFullYear();
const WA_LINK =
  'https://wa.me/5511918952921?text=Oi%2C%20vi%20voc%C3%AA%20no%20Google%20e%20gostaria%20de%20saber%20mais%20sobre%20a%20imers%C3%A3o%20Training%20Camping';
---

<footer class="bg-primary text-white" role="contentinfo">

  <!-- Divisor superior -->
  <div class="h-px bg-gradient-to-r from-transparent via-secondary/40 to-transparent" aria-hidden="true"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-16 md:py-20">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 sm:gap-12 lg:gap-16">

      <!-- Coluna 1: Marca + descrição -->
      <div>
        <a href="#top" class="inline-block mb-6" aria-label="Training Camping — topo da página">
          <Image
            src={logoTrainingCamping}
            alt="Training Camping Logo"
            class="h-16 sm:h-20 lg:h-24 w-auto object-contain"
          />
        </a>
        <p class="font-sans text-white/60 leading-relaxed text-xs sm:text-sm mb-4">
          Imersão presencial de treinamento comportamental para cães. SJC e região.
        </p>
        <!-- CNPJ -->
        <p class="font-sans text-white/30 text-[0.6rem] sm:text-[0.75rem]">
          CNPJ: 49.081.534/0001-89
        </p>
      </div>

      <!-- Coluna 2: Redes sociais -->
      <div>
        <h3 class="font-display text-white/50 uppercase tracking-wider mb-6 text-sm sm:text-base">
          Redes Sociais
        </h3>
        <ul class="space-y-3">
          <li>
            <a
              href="https://www.instagram.com/abeak9"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-3 font-sans text-white/70 hover:text-secondary transition-colors duration-150 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-secondary text-xs sm:text-sm"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
              @abeak9
            </a>
          </li>
          <li>
            <a
              href="https://www.tiktok.com/@abeak9"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-3 font-sans text-white/70 hover:text-secondary transition-colors duration-150 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-secondary text-xs sm:text-sm"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.75a4.85 4.85 0 01-1.01-.06z"/>
              </svg>
              @abeak9
            </a>
          </li>
        </ul>
      </div>

      <!-- Coluna 3: Contato -->
      <div>
        <h3 class="font-display text-white/50 uppercase tracking-wider mb-6 text-sm sm:text-base">
          Contato
        </h3>
        <ul class="space-y-3 mb-6">
          <li>
            <a
              id="btn-footer-whatsapp"
              href={WA_LINK}
              target="_blank"
              rel="noopener noreferrer"
              data-tracking="click-whatsapp-footer"
              data-section="footer"
              class="inline-flex items-center gap-3 font-sans text-white/70 hover:text-secondary transition-colors duration-150 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-secondary text-xs sm:text-sm"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              (11) 91895-2921
            </a>
          </li>
          <li class="flex items-center gap-3 font-sans text-white/50 text-xs sm:text-sm">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
            São José dos Campos / SP
          </li>
        </ul>

        <!-- CTA -->
        <a
          href={WA_LINK}
          target="_blank"
          rel="noopener noreferrer"
          data-tracking="click-whatsapp-footer-cta"
          data-section="footer"
          class="inline-flex items-center gap-2 bg-secondary text-white font-sans font-semibold text-xs sm:text-sm px-4 sm:px-5 py-2 sm:py-3 rounded hover:scale-[1.03] transition-all duration-150 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-secondary"
        >
          Falar no WhatsApp
        </a>
      </div>

    </div>

    <!-- Divisor -->
    <div class="h-px bg-white/10 my-8 sm:my-10" aria-hidden="true"></div>

    <!-- Linha inferior -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 sm:gap-6">
      <p class="font-sans text-white/30 text-[0.6rem] sm:text-[0.75rem]">
        © {currentYear} Training Camping. Todos os direitos reservados.
      </p>
      <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-6">
        <div class="flex items-center gap-4 sm:gap-6">
          <a
            href="/politica-de-privacidade"
            class="font-sans text-white/30 hover:text-white/60 transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-secondary text-[0.6rem] sm:text-[0.75rem]"
          >
            Política de Privacidade
          </a>
          <a
            href="/termos-de-uso"
            class="font-sans text-white/30 hover:text-white/60 transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-secondary text-[0.6rem] sm:text-[0.75rem]"
          >
            Termos de Uso
          </a>
        </div>
        <a
          href="https://adsgator.com.br"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Site desenvolvido por Adsgator"
          class="inline-block"
        >
          <Image
            src={assinaturaAdsgator}
            alt="Desenvolvido por Adsgator"
            class="h-4 sm:h-5 w-auto object-contain opacity-70 hover:opacity-100 transition-opacity"
          />
        </a>
      </div>
    </div>
  </div>
</footer>
